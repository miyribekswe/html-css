<!DOCTYPE html>
<html>
<head>
<style>
.card {
  width: 200px;
  border: 1px solid #ccc;
  padding: 15px;
  text-align: center;
  border-radius: 10px;
}

.follow-btn {
  margin-top: 10px;
  background-color: blue;
  color: white;
  padding: 8px 15px;
  border-radius: 15px;
  display: inline-block;
  text-decoration: none;
}
.p{
    color: #5d655d;
}
.img{
    width: 100px;
}
</style>
</head>
<body>

<div class="card">
  <img src="hacer.jpg" alt="" class="img">
  <h3>miyribekswe</h3>
  <p class="p">6 followers</p>
  <a href="#" class="follow-btn">Follow</a>
</div>

</body>
</html>
