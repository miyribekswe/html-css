<!DOCTYPE html>
<html>
<head>
<title>Forms3</title>
<style>
#fruitsa:hover {
    border: 2px solid green; 
    box-shadow: 0 0 5px green; 
}


#message:hover {
    border: 2px solid green;
    box-shadow: 0 0 5px green;
}


button:hover {
    background-color: green;
    color: white;
    cursor: pointer;
    box-shadow: 0 0 10px green;
}


#fruits, #message{
    border: 1px solid #0096ff;
    padding: 5px;
    transition: all 0.3s ease; 
}
</style>
</head>
<body>
<form action="/submit" method="post">

  <select id="fruitsa" name="fruits">
    <option value="shashterez">Shashtarez</option>
    <option value="salon">Salon</option>
    <option value="banana">Decarator</option>
    <option value="orange">Baseyin</option>
  </select><br><br>

  <label for="message"></label><br>
  <textarea id="message" name="message" rows="5" cols="40" placeholder="Xabaringizdi usi jerge jazin..."></textarea><br><br>

  <button type="submit">Jiberiw</button>
</form>
</body>
